# 仮想環境
.venv/
venv/
env/

# 環境変数（APIキーが含まれるため必須）
.env

# スクレイピング結果（大容量のため除外）
リサーチ結果/

# 画像キャッシュ（大容量のためgit管理外）
img_cache/

# Pythonキャッシュ
__pycache__/
*.pyc
*.pyo
*.pyd

# デバッグ用ファイル
page_source.html

# スクレイピング結果CSV（ルート直下）
aucfan_results_*.csv

# Chromeデバッグプロファイルキャッシュ
.aucfan-chrome-profile/

# macOS
.DS_Store

# VSCode
.vscode/

# Google Drive API 認証情報（機密情報のため除外）
credentials.json
token.json
client_secret_*.json

# Mac別設定ファイル（各Macで個別管理）
*Mac用.env
