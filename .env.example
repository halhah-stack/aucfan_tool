# ──────────────────────────────────────────────
# .env.example → .env にリネームして使用してください
# ──────────────────────────────────────────────

# Gemini API キー（Google AI Studio で取得）
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ──────────────────────────────────────────────
# Google Drive アップロード設定
# ──────────────────────────────────────────────
# true  : scraper Mac が画像を GDrive API で直接アップロード（デフォルト）
#           → credentials.json と token.json が必要
#           → 初回認証: python setup_gdrive_auth.py
# false : GDrive へのアップロードを完全に無効化
#           → GDrive を使わないスタンドアローン運用
#           → credentials.json / token.json / GDrive 系ライブラリが不要
GDRIVE_UPLOAD_ENABLED=true

# ──────────────────────────────────────────────
# サイトロール設定（必須）
# ──────────────────────────────────────────────
# scraper : 十王Mac（スクレイピング側）
#   - 画像を img_cache/ にローカル保存
#   - GDRIVE_UPLOAD_ENABLED=true のとき GDrive/リサーチ結果/セッション名/images/ にもアップロード
#
# reader  : 守谷Mac（リード側）
#   - GDrive ミラーリング済みのため画像は GDrive/リサーチ結果/ を直接参照
#   - GDrive へのアップロードは不要（ミラーリングで自動同期）
#
# ※ CSV・PDF・HTML・items.json はどちらも GDrive に保存（共通）
SITE_ROLE=scraper

# Chrome リモートデバッグ設定（通常は変更不要）
CHROME_DEBUG_HOST=127.0.0.1
CHROME_DEBUG_PORT=9222

# スクレイピング設定（任意）
MIN_DELAY=3.0
MAX_DELAY=5.0
MAX_PAGES=500
ITEMS_PER_PAGE=50

# フィルタリング設定（任意）
MIN_PRICE=1000
MAX_PRICE=3000
MIN_GROUP_SIZE=5
PHASH_THRESHOLD=2

# Flask 設定（任意）
FLASK_PORT=5001

# Gemini モデル設定（任意）
GEMINI_MODEL_TEXT=gemini-2.5-flash
GEMINI_MODEL_VISION=gemini-2.5-flash

# Gemini を無効化したい場合（pHashのみで動作）
GEMINI_ENABLED=true

# GDrive アップロードを無効化する場合（スタンドアローン運用）
# GDRIVE_UPLOAD_ENABLED=false
