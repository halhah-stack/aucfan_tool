# ──────────────────────────────────────────────
# .env.example → .env にリネームして使用してください
# ──────────────────────────────────────────────

# Gemini API キー（Google AI Studio で取得）
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Chrome リモートデバッグ設定（通常は変更不要）
CHROME_DEBUG_HOST=127.0.0.1
CHROME_DEBUG_PORT=9222

# スクレイピング設定（任意）
MIN_DELAY=3.0
MAX_DELAY=5.0
MAX_PAGES=500
ITEMS_PER_PAGE=50

# フィルタリング設定（任意）
MIN_PRICE=1000
MAX_PRICE=3000
MIN_GROUP_SIZE=5

# Flask 設定（任意）
FLASK_PORT=5000

# 出力ディレクトリ名（任意）
OUTPUT_BASE_DIR=リサーチ結果

# Gemini を無効化したい場合（pHashのみで動作）
GEMINI_ENABLED=true
